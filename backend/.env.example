# SkillSync Backend - Environment Variables

# Application
APP_NAME=SkillSync API
ENVIRONMENT=development
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# CORS - Frontend URL
FRONTEND_URL=http://localhost:3000

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-this-min-32-chars-abc123xyz789
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MongoDB Configuration
# Local MongoDB:
MONGODB_URL=mongodb://skillsync_admin:skillsync123@localhost:27017/skillsync?authSource=admin
DATABASE_NAME=skillsync

# MongoDB Atlas (Cloud - Alternative):
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/skillsync?retryWrites=true&w=majority
# DATABASE_NAME=skillsync

# File Upload (Optional)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880


